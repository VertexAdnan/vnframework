# App Configuration
APP_TITLE="VN Framework"
APP_DESCRIPTION="A powerful framework for building applications"

# ============================================
# PRIMARY DATABASE (default)
# ============================================
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=vnframework
DB_SSL=false

# ============================================
# SECONDARY DATABASES (optional - çoklu veritabanı)
# ============================================

# MikroServer - MSSQL (192.168.1.5:1433)
MIKROSERVER_DB_TYPE=mssql
MIKROSERVER_DB_HOST=192.168.1.5
MIKROSERVER_DB_PORT=1433
MIKROSERVER_DB_USER=sa
MIKROSERVER_DB_PASSWORD=yourpassword
MIKROSERVER_DB_NAME=MikroServerDB
MIKROSERVER_DB_SSL=true

# B2BServer - MSSQL (192.168.1.6:1433)
B2BSERVER_DB_TYPE=mssql
B2BSERVER_DB_HOST=192.168.1.6
B2BSERVER_DB_PORT=1433
B2BSERVER_DB_USER=sa
B2BSERVER_DB_PASSWORD=yourpassword
B2BSERVER_DB_NAME=B2BServerDB
B2BSERVER_DB_SSL=true

# MongoServer - MongoDB (192.168.1.5:27017)
MONGOSERVER_DB_TYPE=mongodb
MONGOSERVER_DB_HOST=192.168.1.5
MONGOSERVER_DB_PORT=27017
MONGOSERVER_DB_USER=admin
MONGOSERVER_DB_PASSWORD=yourpassword
MONGOSERVER_DB_NAME=MongoServerDB
MONGOSERVER_DB_AUTH_SOURCE=admin
# Veya direkt URI kullan:
# MONGOSERVER_DB_URI=mongodb://admin:password@192.168.1.5:27017/MongoServerDB

# ============================================
# DIĞER VERİTABANI ÖRNEKLERİ
# ============================================

# MySQL örneği
# ANALYTICS_DB_TYPE=mysql
# ANALYTICS_DB_HOST=localhost
# ANALYTICS_DB_PORT=3306
# ANALYTICS_DB_USER=root
# ANALYTICS_DB_PASSWORD=yourpassword
# ANALYTICS_DB_NAME=analytics
# ANALYTICS_DB_SSL=false

# SQLite örneği (local)
# CACHE_DB_TYPE=sqlite
# CACHE_DB_FILENAME=./cache.db

